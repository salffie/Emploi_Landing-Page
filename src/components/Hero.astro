---
const WA_URL = 'https://wa.me/528448704878';
---

<section class="b-hero" aria-labelledby="hero-heading">
  <div class="b-hero-watermark" aria-hidden="true">CV</div>
  <div class="b-hero-inner b-container">
    <div class="b-hero-badge b-reveal">
      <span class="b-hero-badge-dot" aria-hidden="true"></span>
      4 años posicionando profesionales
    </div>
    <h1 class="b-hero-h1 b-reveal b-reveal-delay-1" id="hero-heading">
      Optimiza<br />
      tu CV.<br />
      <span class="b-hero-h1-block">Consigue.</span>
    </h1>
    <div class="b-hero-grid">
      <p class="b-hero-sub b-reveal b-reveal-delay-2">
        Transformamos tu perfil profesional con estrategias de Recursos Humanos,
        redacción especializada y diseño optimizado para reclutadores y sistemas ATS.
      </p>
      <div class="b-reveal b-reveal-delay-3">
        <a href={WA_URL} class="b-hero-btn" target="_blank" rel="noopener noreferrer">
          SOLICITA TU CV
          <span class="b-hero-btn-arrow" aria-hidden="true">→</span>
        </a>
      </div>
    </div>
    <div class="b-stats" role="list" aria-label="Estadísticas de emploi">
      <div class="b-stat b-reveal b-reveal-delay-1" role="listitem">
        <div class="b-stat-n" data-count="92" data-prefix="+" data-suffix="%">+92%</div>
        <div class="b-stat-l">entrevistas</div>
      </div>
      <div class="b-stat b-reveal b-reveal-delay-2" role="listitem">
        <div class="b-stat-n" data-count="850" data-prefix="+">+850</div>
        <div class="b-stat-l">perfiles</div>
      </div>
      <div class="b-stat b-reveal b-reveal-delay-3" role="listitem">
        <div class="b-stat-n">4 AÑOS</div>
        <div class="b-stat-l">experiencia</div>
      </div>
      <div class="b-stat b-reveal b-reveal-delay-4" role="listitem">
        <div class="b-stat-n">100%</div>
        <div class="b-stat-l">digital</div>
      </div>
    </div>
  </div>
</section>
