---
---

<section class="b-solucion" aria-labelledby="solucion-heading">
  <div class="b-container">
    <div class="b-solucion-inner">
      <div>
        <div class="b-solucion-label b-reveal">La solución</div>
        <h2 class="b-solucion-h2 b-reveal b-reveal-delay-1" id="solucion-heading">
          Recursos Humanos<br />
          <span style="color:var(--red)">aplicado</span>, no<br />
          diseño decorativo.
        </h2>
        <p class="b-solucion-sub b-reveal b-reveal-delay-2">
          Usamos el mismo criterio con el que los reclutadores deciden — y lo aplicamos desde tu lado.
        </p>
        <div class="b-solucion-list b-reveal b-reveal-delay-3">
          <div class="b-solucion-item">
            <span class="b-solucion-num" aria-hidden="true">01</span>Redacción con verbos de impacto
          </div>
          <div class="b-solucion-item">
            <span class="b-solucion-num" aria-hidden="true">02</span>Estructura ATS-compatible
          </div>
          <div class="b-solucion-item">
            <span class="b-solucion-num" aria-hidden="true">03</span>Diseño alineado a tu sector
          </div>
          <div class="b-solucion-item">
            <span class="b-solucion-num" aria-hidden="true">04</span>Soporte hasta entrega final
          </div>
        </div>
      </div>
      <div
        class="b-cv-mock b-reveal b-reveal-delay-2"
        role="img"
        aria-label="Ejemplo de CV optimizado por emploi"
      >
        <div class="b-cv-accent" aria-hidden="true"></div>
        <div class="b-cv-inner">
          <div class="b-cv-name">Nombre Apellido</div>
          <div class="b-cv-role">DIRECTOR FINANCIERO · CFO</div>
          <div class="b-cv-rule"></div>
          <div class="b-cv-section">
            <div class="b-cv-section-label">EXPERIENCIA</div>
            <div class="b-cv-line-thick" style="width:82%"></div>
            <div class="b-cv-line-thin" style="width:61%"></div>
            <div class="b-cv-line-thick" style="width:74%"></div>
            <div class="b-cv-line-thin" style="width:55%"></div>
          </div>
          <div class="b-cv-section">
            <div class="b-cv-section-label">EDUCACIÓN</div>
            <div class="b-cv-line-thick" style="width:65%"></div>
            <div class="b-cv-line-thin" style="width:77%"></div>
            <div class="b-cv-line-thick" style="width:58%"></div>
            <div class="b-cv-line-thin" style="width:48%"></div>
          </div>
          <div class="b-cv-section">
            <div class="b-cv-section-label">HABILIDADES</div>
            <div class="b-cv-line-thick" style="width:70%"></div>
            <div class="b-cv-line-thin" style="width:53%"></div>
            <div class="b-cv-line-thick" style="width:68%"></div>
            <div class="b-cv-line-thin" style="width:44%"></div>
          </div>
          <div class="b-cv-badge">✓ ATS APROBADO · 98/100</div>
        </div>
      </div>
    </div>
  </div>
</section>
