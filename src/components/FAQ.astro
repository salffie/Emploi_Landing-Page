<section id="faq" class="b-faq" aria-labelledby="faq-heading">
  <div class="b-container--sm">
    <div class="b-section-label b-reveal">FAQ</div>
    <h2 class="b-faq-h2 b-reveal b-reveal-delay-1" id="faq-heading">
      Dudas <span style="color:var(--red)">antes</span> de decidir.
    </h2>
    <div class="b-faq-list" id="faq-list"></div>
  </div>
</section>

<script>
  const FAQS: [string, string][] = [
    ['¿Cuánto tiempo tarda la entrega?',              'Nuestro tiempo de entrega habitual es de 24 a 48 horas hábiles a partir de la confirmación de pago y recepción de la información necesaria. En proyectos especiales, el tiempo puede variar.'],
    ['¿Qué necesito para empezar?',                   'Solo necesitamos tu CV actual o tu información laboral básica. Si deseas incluir fotografía, también puedes enviarla para optimizar su presentación profesional.'],
    ['¿Qué es un CV ATS?',                            'Es un currículum diseñado para ser compatible con sistemas automatizados de reclutamiento (ATS), aumentando la probabilidad de superar filtros digitales y llegar a reclutadores.'],
    ['¿Hacen entregas internacionales?',               'Sí. Nuestro servicio es 100% digital, por lo que trabajamos con clientes dentro y fuera de México.'],
    ['¿Formas de pago?',                              'Aceptamos transferencia y depósito bancario. Para iniciar el servicio solicitamos un anticipo, y el archivo final se entrega al liquidar el pago.'],
    ['¿Puedo pedir cambios?',                         'Sí. Antes de liquidar tu servicio, puedes solicitar ajustes en redacción, estructura y contenido sin costo adicional. Los cambios de diseño no están incluidos. Una vez entregado el archivo final, cualquier modificación posterior tiene costo.'],
    ['¿Manejan pedidos urgentes o exprés?',           'Sí. Contamos con modalidad urgente/exprés según disponibilidad operativa. Puede aplicar un costo adicional.'],
    ['¿Realizan CV empresarial o para empresas?',     'Sí. También desarrollamos CV corporativos, perfiles ejecutivos, presentaciones empresariales y materiales de identidad profesional para empresas y equipos de trabajo.'],
  ];

  let openFAQ = 0;
  const faqList = document.getElementById('faq-list')!;

  function renderFAQ() {
    faqList.innerHTML = FAQS.map(([q, a], i) => {
      const open = i === openFAQ;
      return `
        <div class="b-faq-item${open ? ' b-faq-item--open' : ''}">
          <button class="b-faq-btn" aria-expanded="${open}" data-faq="${i}"
                  id="faq-btn-${i}" aria-controls="faq-ans-${i}">
            <span class="b-faq-q">${q}</span>
            <span class="b-faq-icon" aria-hidden="true">+</span>
          </button>
          <div class="b-faq-a-wrap${open ? ' b-faq-a-wrap--open' : ''}"
               id="faq-ans-${i}" role="region" aria-labelledby="faq-btn-${i}">
            <p class="b-faq-a">${a}</p>
          </div>
        </div>
      `;
    }).join('');

    faqList.querySelectorAll<HTMLButtonElement>('.b-faq-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        openFAQ = openFAQ === Number(btn.dataset.faq) ? -1 : Number(btn.dataset.faq);
        renderFAQ();
      });
    });
  }

  renderFAQ();
</script>
